      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- MOBILE NAV DRAWER -->
<div class="mobile-nav" id="mobile-nav">
  <ul>
    <li><a href="#services"     onclick="closeMenu()">Services</a></li>
    <li><a href="#credentials"  onclick="closeMenu()">Credentials</a></li>
    <li><a href="#why"          onclick="closeMenu()">Why Asenso</a></li>
    <li><a href="#projects"     onclick="closeMenu()">Projects</a></li>
    <li><a href="#senior-staff" onclick="closeMenu()">Senior Staff</a></li>
    <li><a href="#contact"      onclick="closeMenu()">Contact</a></li>
  </ul>
  <a href="#contact" class="btn-gold" onclick="closeMenu()">Start a Project</a>
  <div class="mobile-nav-identity">
    <span>Family-Owned Business</span>
    <span>Minority-Owned Business</span>
    <span>Small Business (SBE)</span>
    <span>Pursuing DBE Certification</span>
  </div>
</div>

<!-- IDENTITY BANNER -->
<div id="identity-band">
  <div class="identity-inner">
    <span class="id-tag">Family-Owned Business</span>
    <span class="id-tag">Minority-Owned Business</span>
    <span class="id-tag">Small Business (SBE)</span>
    <span class="id-tag pursuing">Pursuing DBE Certification</span>
  </div>
</div>

<!-- HERO -->
<section id="hero">
  <div class="pattern-bg">
    <svg viewBox="0 0 900 700" preserveAspectRatio="xMidYMid slice">
      <defs>
        <pattern id="geo" x="0" y="0" width="60" height="52" patternUnits="userSpaceOnUse">
          <polygon points="30,2 58,17 58,35 30,50 2,35 2,17" fill="none" stroke="#EAE2D6" stroke-width=".6" opacity=".04"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#geo)"/>
    </svg>
  </div>
  <div class="hero-inner">
    <div>
      <div class="hero-eyebrow">ICC-Certified · Southern California</div>
      <h1>Certified expertise.<br>Reliable delivery.<br><em>Every project.</em></h1>
      <p class="hero-lead">
        Asenso provides ICC-certified special inspections, structural observation, threshold
        inspections, and QA/QC services — with a credential stack deep enough to cover any IBC
        Chapter 17 scope, and a team responsive enough to move at your pace.
      </p>
      <p class="hero-family">Family-owned and family-staffed — we've built this firm on the certifications, the relationships, and the reputation we're proud to put our name on.</p>
      <div class="hero-cta">
        <a href="#contact" class="btn-gold">Start a Project</a>
        <a href="#credentials" class="btn-ghost">View Credentials</a>
      </div>
      <div class="jurisdiction-row">
        <span class="juris-label">Licensed in</span>
        <span class="juris-tag">LA City</span>
        <span class="juris-tag">LA County</span>
        <span class="juris-tag">Orange County</span>
        <span class="juris-tag">Riverside County</span>
        <span class="juris-tag">San Bernardino County</span>
        <span class="juris-tag">Long Beach</span>
      </div>
    </div>
    <div class="hero-creds">
      <div class="cred-pill">
        <svg class="cred-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <div><div class="cred-label">ICC · AWS · ACI · IFC Certified</div><div class="cred-sub">Full IBC Ch. 17 scope coverage across the team</div></div>
      </div>
      <div class="cred-pill">
        <svg class="cred-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <div><div class="cred-label">24–48 Hour Mobilization</div><div class="cred-sub">7 days a week across Southern California</div></div>
      </div>
      <div class="cred-pill">
        <svg class="cred-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        <div><div class="cred-label">Same-Day Field Reports</div><div class="cred-sub">Digital delivery, AHJ-ready documentation</div></div>
      </div>
      <div class="cred-pill">
        <svg class="cred-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
        <div><div class="cred-label">Deep DSA Experience</div><div class="cred-sub">K–12, community college &amp; public works</div></div>
      </div>
    </div>
  </div>
</section>

<!-- DIFF BAND -->
<div id="diff-band">
  <div class="diff-inner">
    <div class="diff-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      <strong>Founder-led firm</strong>
      <span>You work with the principals — not an account manager at a national lab.</span>
    </div>
    <div class="diff-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      <strong>24–48 hr scheduling</strong>
      <span>Fast mobilization when your schedule can't wait for a lab's dispatch queue.</span>
    </div>
    <div class="diff-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      <strong>Inspector continuity</strong>
      <span>The same certified inspector on your project, start to finish. No rotating bodies.</span>
    </div>
    <div class="diff-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
      <strong>AHJ-ready reports</strong>
      <span>Same-day digital field reports formatted for the building department, SEOR, and owner.</span>
    </div>
  </div>
</div>

<!-- SERVICES -->
<section id="services">
  <div class="section-inner">
    <div class="section-tag">What We Do</div>
    <h2>Special &amp; Deputy Inspection Services</h2>
    <p class="section-lead">ICC-certified across the full IBC Chapter 17 and CBC scope. Licensed in LA City, LA County, Orange County, Riverside, San Bernardino, and Long Beach.</p>
    <div class="services-layout">
      <div class="service-nav">
        <div class="service-nav-label">Jump to</div>
        <ul class="service-nav-list">
          <li><a href="#svc-special">Special Inspections</a></li>
          <li><a href="#svc-structural">Structural Observation</a></li>
          <li><a href="#svc-threshold">Threshold Inspections</a></li>
          <li><a href="#svc-qaqc">QA/QC Program Management</a></li>
        </ul>
      </div>
      <div class="service-panels">
        <div class="service-panel" id="svc-special">
          <div class="panel-header"><h3>Special Inspections</h3><span class="panel-code">IBC Ch. 17 / CBC</span></div>
          <p class="panel-desc">Continuous and periodic special inspections per the project Statement of Special Inspections — performed by ICC-certified inspectors licensed in the relevant jurisdiction.</p>
          <ul class="panel-items">
            <li>Reinforcing Steel Placement</li>
            <li>Concrete Placement &amp; Curing</li>
            <li>Shotcrete Placement</li>
            <li>Pre-Stress &amp; Post-Tensioned Concrete</li>
            <li>Structural Steel Welding</li>
            <li>High-Strength Bolting</li>
            <li>Reinforced Masonry Construction</li>
            <li>Epoxy Anchor Installation</li>
            <li>Mechanical Anchors</li>
            <li>Non-Destructive Testing</li>
            <li>Fireproofing</li>
            <li>Structural Wood</li>
            <li>Exterior Insulation &amp; Finish Systems (EIFS)</li>
            <li>Welder Qualifications</li>
            <li>Steel &amp; Welding Fabricator Shop Inspections</li>
          </ul>
        </div>
        <div class="service-panel" id="svc-structural">
          <div class="panel-header"><h3>Structural Observation</h3><span class="panel-code">ASCE 7</span></div>
          <p class="panel-desc">Structural observation services coordinated with the Structural Engineer of Record — ensuring field conditions match design intent at every required phase.</p>
          <ul class="panel-items">
            <li>Phased site visits per observation program</li>
            <li>Deficiency tracking &amp; resolution log</li>
            <li>SEOR coordination and reporting</li>
            <li>Final structural observation letter for AHJ</li>
            <li>Coordination with building department at closeout</li>
          </ul>
        </div>
        <div class="service-panel" id="svc-threshold">
          <div class="panel-header"><h3>Threshold Inspections</h3><span class="panel-code">CBC §1705</span></div>
          <p class="panel-desc">Threshold building inspection services for projects triggering mandatory structural observation — including large concrete and post-tensioned structures.</p>
          <ul class="panel-items">
            <li>Concrete &amp; post-tensioned slab systems</li>
            <li>Moment frames and shear wall construction</li>
            <li>Sequential phase documentation</li>
            <li>Threshold inspection reports for AHJ</li>
          </ul>
        </div>
        <div class="service-panel" id="svc-qaqc">
          <div class="panel-header"><h3>QA/QC Program Management</h3><span class="panel-code">Owner · GC · Agency</span></div>
          <p class="panel-desc">Embedded quality assurance and control support for contractors, owners, and public agencies who need an independent eye on the work throughout construction.</p>
          <ul class="panel-items">
            <li>Project-specific QA/QC plan development</li>
            <li>Pre-pour &amp; pre-placement checklists</li>
            <li>Non-conformance tracking &amp; resolution</li>
            <li>Owner's representative support</li>
            <li>Contractor QC program review</li>
            <li>Closeout documentation packages</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CREDENTIALS -->
<section id="credentials">
  <div class="section-inner">
    <div class="section-tag">Our Team's Credentials</div>
    <h2>The certification stack<br>behind every inspection.</h2>

    <div class="creds-intro">
      <p>Every inspector on the Asenso team holds active, verified certifications from the leading bodies in the industry — ICC, AWS, ACI, and IFC. We don't say "ICC certified" as a marketing line. Below is the full credential inventory our team collectively holds, organized by certifying body.</p>
      <div class="cert-summary">
        <div class="cert-summary-item"><div class="cert-summary-body">ICC</div><div class="cert-summary-label">Certified</div></div>
        <div class="cert-summary-item"><div class="cert-summary-body">AWS</div><div class="cert-summary-label">Welding</div></div>
        <div class="cert-summary-item"><div class="cert-summary-body">ACI</div><div class="cert-summary-label">Field &amp; Anchor</div></div>
        <div class="cert-summary-item"><div class="cert-summary-body">IFC</div><div class="cert-summary-label">Firestop</div></div>
        <div class="cert-summary-item"><div class="cert-summary-body">LA City</div><div class="cert-summary-label">Registered</div></div>
        <div class="cert-summary-item"><div class="cert-summary-body">Long Beach</div><div class="cert-summary-label">Registered</div></div>
      </div>
    </div>

    <div class="cert-tabs">
      <button class="cert-tab active" onclick="showTab('icc', this)">ICC</button>
      <button class="cert-tab" onclick="showTab('aws', this)">AWS Welding</button>
      <button class="cert-tab" onclick="showTab('aci', this)">ACI</button>
      <button class="cert-tab" onclick="showTab('ifc', this)">IFC Firestop</button>
      <button class="cert-tab" onclick="showTab('jurisdictions', this)">Jurisdiction Approvals</button>
    </div>

    <!-- ICC -->
    <div class="cert-body-section active" id="tab-icc">
      <div class="cert-category-grid">
        <div class="cert-row"><span class="cert-row-name">Master of Special Inspection</span></div>
        <div class="cert-row"><span class="cert-row-name">Reinforced Concrete Special Inspector</span></div>
        <div class="cert-row"><span class="cert-row-name">Prestressed Concrete Special Inspector</span></div>
        <div class="cert-row"><span class="cert-row-name">Structural Steel &amp; Bolting Special Inspector</span></div>
        <div class="cert-row"><span class="cert-row-name">Structural Welding Special Inspector</span></div>
        <div class="cert-row"><span class="cert-row-name">Structural Masonry Special Inspector</span></div>
        <div class="cert-row"><span class="cert-row-name">Spray-Applied Fireproofing Special Inspector</span></div>
        <div class="cert-row"><span class="cert-row-name">Firestopping Credential of Learning Achievement</span></div>
        <div class="cert-row"><span class="cert-row-name">CA Commercial Building Inspector</span></div>
        <div class="cert-row"><span class="cert-row-name">CA Commercial Plumbing Inspector</span></div>
      </div>
    </div>

    <!-- AWS -->
    <div class="cert-body-section" id="tab-aws">
      <div class="cert-category-grid">
        <div class="cert-row"><span class="cert-row-name">AWS Certified Welding Inspector (CWI)</span></div>
      </div>
