<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Asenso — Special Inspections & Deputy Inspection | Southern California</title>
  <meta name="description" content="ICC-certified special inspections and deputy inspection across LA, Orange County, Riverside and San Bernardino. Family-owned, minority-owned, pursuing DBE. Same-day reports.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --navy:     #142235;
      --charcoal: #2A2F36;
      --sand:     #EAE2D6;
      --stone:    #D6D1C8;
      --gold:     #B8924A;
      --white:    #FDFAF7;
      --text:     #2A2F36;
      --muted:    #7A7670;
      --border:   rgba(42,47,54,0.10);
      --radius:   6px;
      --max:      1160px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { background: var(--white); color: var(--text); font-family: 'Manrope', sans-serif; font-size: 16px; line-height: 1.7; -webkit-font-smoothing: antialiased; }
    .pattern-bg { position: absolute; inset: 0; z-index: 0; overflow: hidden; pointer-events: none; }
    .pattern-bg svg { width: 100%; height: 100%; }

    /* NAV */
    nav { position: sticky; top: 0; z-index: 100; background: rgba(253,250,247,0.96); backdrop-filter: blur(16px); border-bottom: 1px solid var(--border); padding: 0 2rem; }
    .nav-inner { max-width: var(--max); margin: 0 auto; display: flex; align-items: center; justify-content: space-between; height: 68px; }
    .logo { display: flex; align-items: center; gap: 13px; text-decoration: none; }
    .logo-mark { width: 36px; height: 36px; flex-shrink: 0; }
    .logo-text { display: flex; flex-direction: column; line-height: 1.1; gap: 2px; }
    .logo-name { font-size: 15px; font-weight: 800; letter-spacing: 0.2em; color: var(--navy); text-transform: uppercase; }
    .logo-sub  { font-size: 9px; font-weight: 600; letter-spacing: 0.22em; color: var(--gold); text-transform: uppercase; }
    .nav-links { display: flex; align-items: center; gap: 2.2rem; list-style: none; }
    .nav-links a { text-decoration: none; color: var(--muted); font-size: 13px; font-weight: 500; transition: color .2s; }
    .nav-links a:hover { color: var(--navy); }
    .btn-nav { background: var(--navy); color: var(--white); font-family: 'Manrope', sans-serif; font-size: 12px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 10px 22px; border: none; border-radius: 100px; cursor: pointer; text-decoration: none; display: inline-block; transition: background .2s, transform .15s; }
    .btn-nav:hover { background: #1c3148; transform: translateY(-1px); }

    /* IDENTITY BANNER */
    #identity-band { background: var(--navy); padding: .75rem 2rem; border-bottom: 1px solid rgba(255,255,255,.06); }
    .identity-inner { max-width: var(--max); margin: 0 auto; display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: .4rem 1.6rem; }
    .id-tag { font-size: 10.5px; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: rgba(234,226,214,.5); display: flex; align-items: center; gap: 6px; }
    .id-tag::before { content: ''; width: 4px; height: 4px; background: var(--gold); border-radius: 50%; flex-shrink: 0; }
    .id-tag.pursuing { color: rgba(184,146,74,.65); }
    .id-tag.pursuing::before { background: rgba(184,146,74,.5); }

    /* HERO */
    #hero { min-height: 90vh; display: flex; align-items: center; background: var(--navy); position: relative; overflow: hidden; padding: 6rem 2rem; }
    .hero-inner { max-width: var(--max); margin: 0 auto; display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 5rem; align-items: center; position: relative; z-index: 1; }
    .hero-eyebrow { font-size: 10px; font-weight: 700; letter-spacing: .34em; text-transform: uppercase; color: var(--gold); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 12px; }
    .hero-eyebrow::before { content: ''; display: block; width: 28px; height: 1px; background: var(--gold); }
    h1 { font-size: clamp(2.8rem, 4.8vw, 4.2rem); font-weight: 800; line-height: 1.04; letter-spacing: -.025em; color: var(--white); margin-bottom: 1.5rem; }
    h1 em { font-style: normal; color: var(--gold); }
    .hero-lead { font-size: 16px; color: rgba(234,226,214,.58); line-height: 1.85; margin-bottom: .85rem; max-width: 500px; font-weight: 400; }
    .hero-family { font-size: 13px; color: rgba(184,146,74,.65); line-height: 1.65; margin-bottom: 2.2rem; max-width: 480px; font-style: italic; }
    .hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2.4rem; }
    .btn-gold { background: var(--gold); color: var(--navy); font-family: 'Manrope', sans-serif; font-size: 12px; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; padding: 13px 28px; border: none; border-radius: 100px; cursor: pointer; text-decoration: none; display: inline-block; transition: opacity .2s, transform .15s; }
    .btn-gold:hover { opacity: .88; transform: translateY(-1px); }
    .btn-ghost { background: transparent; color: rgba(234,226,214,.75); font-family: 'Manrope', sans-serif; font-size: 12px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 13px 28px; border: 1.5px solid rgba(234,226,214,.2); border-radius: 100px; cursor: pointer; text-decoration: none; display: inline-block; transition: border-color .2s; }
    .btn-ghost:hover { border-color: rgba(234,226,214,.5); }
    .jurisdiction-row { display: flex; flex-wrap: wrap; gap: .5rem; align-items: center; }
    .juris-label { font-size: 10px; font-weight: 600; letter-spacing: .15em; text-transform: uppercase; color: rgba(234,226,214,.28); margin-right: .2rem; }
    .juris-tag { font-size: 11px; font-weight: 600; color: rgba(234,226,214,.5); background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.08); border-radius: 100px; padding: 4px 12px; white-space: nowrap; }
    .hero-creds { display: flex; flex-direction: column; gap: .85rem; }
    .cred-pill { display: flex; align-items: flex-start; gap: 14px; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.08); border-radius: 10px; padding: 1rem 1.2rem; }
    .cred-icon { width: 18px; height: 18px; color: var(--gold); flex-shrink: 0; margin-top: 2px; }
    .cred-label { font-size: 12px; font-weight: 700; color: var(--white); margin-bottom: 2px; }
    .cred-sub   { font-size: 11px; color: rgba(234,226,214,.42); line-height: 1.4; }

    /* SHARED */
    section { padding: 6rem 2rem; }
    .section-inner { max-width: var(--max); margin: 0 auto; }
    .section-tag { font-size: 10px; font-weight: 700; letter-spacing: .32em; text-transform: uppercase; color: var(--gold); margin-bottom: 1rem; }
    h2 { font-size: clamp(1.9rem, 3vw, 2.6rem); font-weight: 800; line-height: 1.07; letter-spacing: -.02em; color: var(--navy); margin-bottom: 1rem; }
    .section-lead { font-size: 16px; color: var(--muted); max-width: 560px; margin-bottom: 3.5rem; line-height: 1.8; font-weight: 400; }

    /* DIFF BAND */
    #diff-band { background: var(--sand); padding: 2.8rem 2rem; }
    .diff-inner { max-width: var(--max); margin: 0 auto; display: grid; grid-template-columns: repeat(4,1fr); gap: 2rem; }
    .diff-item { display: flex; flex-direction: column; gap: .35rem; }
    .diff-item svg { width: 22px; height: 22px; color: var(--gold); margin-bottom: .4rem; }
    .diff-item strong { font-size: .9rem; font-weight: 700; color: var(--navy); }
    .diff-item span { font-size: 13px; color: var(--muted); line-height: 1.5; }

    /* SERVICES */
    #services { background: var(--white); }
    .services-layout { display: grid; grid-template-columns: 1fr 1.6fr; gap: 4rem; align-items: start; }
    .service-nav { position: sticky; top: 88px; max-height: calc(100vh - 120px); overflow-y: auto; }
    .service-panel { scroll-margin-top: 100px; }
    .service-nav-label { font-size: 10px; font-weight: 700; letter-spacing: .2em; text-transform: uppercase; color: var(--muted); margin-bottom: 1rem; }
    .service-nav-list { list-style: none; display: flex; flex-direction: column; gap: .2rem; }
    .service-nav-list li a { display: block; padding: .55rem .85rem; border-radius: var(--radius); text-decoration: none; font-size: 13.5px; font-weight: 500; color: var(--muted); transition: background .15s, color .15s; border-left: 2px solid transparent; }
    .service-nav-list li a:hover { background: var(--sand); color: var(--navy); border-left-color: var(--gold); }
    .service-panels { display: flex; flex-direction: column; gap: 2rem; }
    .service-panel { background: var(--white); border: 1px solid var(--border); border-radius: 12px; padding: 2.2rem 2rem; transition: border-color .2s; position: relative; overflow: hidden; }
    .service-panel::before { content: ''; position: absolute; top: 0; left: 0; bottom: 0; width: 3px; background: var(--gold); opacity: 0; transition: opacity .2s; }
    .service-panel:hover { border-color: rgba(184,146,74,.3); }
    .service-panel:hover::before { opacity: 1; }
    .panel-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: .75rem; }
    .panel-header h3 { font-size: 1.1rem; font-weight: 800; color: var(--navy); }
    .panel-code { font-size: 10px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--gold); background: rgba(184,146,74,.1); padding: 4px 10px; border-radius: 100px; white-space: nowrap; flex-shrink: 0; }
    .panel-desc { font-size: 14px; color: var(--muted); line-height: 1.75; margin-bottom: 1.2rem; }
    .panel-items { display: grid; grid-template-columns: 1fr 1fr; gap: .4rem .75rem; list-style: none; }
    .panel-items li { display: flex; align-items: flex-start; gap: 8px; font-size: 13px; color: var(--charcoal); line-height: 1.5; }
    .panel-items li::before { content: ''; width: 4px; height: 4px; background: var(--gold); flex-shrink: 0; margin-top: 7px; clip-path: polygon(50% 0%,0% 100%,100% 100%); }

    /* CREDENTIALS SECTION */
    #credentials { background: var(--sand); }
    .creds-intro { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; margin-bottom: 3.5rem; }
    .creds-intro p { font-size: 15px; color: var(--muted); line-height: 1.8; }

    /* cert body tabs */
    .cert-tabs { display: flex; gap: .5rem; flex-wrap: wrap; margin-bottom: 2rem; }
    .cert-tab { font-size: 11px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; padding: 6px 14px; border-radius: 100px; border: 1.5px solid var(--stone); background: transparent; color: var(--muted); cursor: pointer; transition: all .15s; font-family: 'Manrope', sans-serif; }
    .cert-tab.active, .cert-tab:hover { background: var(--navy); color: var(--white); border-color: var(--navy); }

    .cert-body-section { display: none; }
    .cert-body-section.active { display: block; }

    /* team grid */
    .team-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.25rem; }
    .team-card { background: var(--white); border: 1px solid var(--border); border-radius: 12px; padding: 1.6rem; }
    .team-card-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: 1.1rem; }
    .team-name { font-size: .95rem; font-weight: 800; color: var(--navy); letter-spacing: -.01em; }
    .team-cert-num { font-size: 10px; font-weight: 600; letter-spacing: .06em; color: var(--muted); margin-top: 2px; }
    .team-expires { font-size: 10px; font-weight: 600; letter-spacing: .06em; color: rgba(184,146,74,.8); background: rgba(184,146,74,.1); padding: 3px 9px; border-radius: 100px; white-space: nowrap; flex-shrink: 0; }
    .team-certs { list-style: none; display: flex; flex-direction: column; gap: .4rem; }
    .team-certs li { display: flex; align-items: flex-start; gap: 8px; font-size: 12.5px; color: var(--muted); line-height: 1.4; }
    .team-certs li::before { content: ''; width: 4px; height: 4px; background: var(--gold); flex-shrink: 0; margin-top: 6px; clip-path: polygon(50% 0%,0% 100%,100% 100%); }
    .team-certs li strong { color: var(--charcoal); font-weight: 600; }

    /* jurisdiction grid */
    .juris-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.25rem; }
    .juris-card { background: var(--white); border: 1px solid var(--border); border-radius: 12px; padding: 1.6rem; }
    .juris-card-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: 1rem; }
    .juris-authority { font-size: .92rem; font-weight: 800; color: var(--navy); }
    .juris-cert-id { font-size: 10px; font-weight: 600; color: var(--muted); }

    /* cert summary bar */
    .cert-summary { display: grid; grid-template-columns: repeat(6,1fr); gap: 1rem; margin-bottom: 3rem; }
    .cert-summary-item { background: var(--white); border: 1px solid var(--border); border-radius: 10px; padding: 1.1rem 1rem; text-align: center; }
    .cert-summary-body { font-size: 1rem; font-weight: 800; color: var(--navy); letter-spacing: -.01em; margin-bottom: 2px; }
    .cert-summary-label { font-size: 10px; font-weight: 600; letter-spacing: .06em; text-transform: uppercase; color: var(--muted); }

    /* CERT CATEGORY GRID (team-level, no names) */
    .cert-category-grid { display: flex; flex-direction: column; gap: .5rem; }
    .cert-row { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: .75rem 1rem; background: var(--white); border: 1px solid var(--border); border-radius: var(--radius); }
    .cert-row-name { font-size: 14px; font-weight: 500; color: var(--charcoal); }
    .cert-row-count { font-size: 11px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: var(--gold); background: rgba(184,146,74,.1); padding: 3px 10px; border-radius: 100px; white-space: nowrap; flex-shrink: 0; }

    /* SENIOR STAFF */
    #senior-staff { background: var(--sand); }
    .staff-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
    .staff-card { background: var(--white); border: 1px solid var(--border); border-radius: 14px; padding: 2rem; }
    .staff-card-top { display: flex; align-items: flex-start; gap: 1rem; margin-bottom: 1.5rem; }
    .staff-avatar { width: 48px; height: 48px; border-radius: 10px; background: var(--navy); color: var(--gold); font-size: 13px; font-weight: 800; letter-spacing: .04em; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .staff-name  { font-size: 1rem; font-weight: 800; color: var(--navy); letter-spacing: -.01em; margin-bottom: 2px; }
    .staff-title { font-size: 12.5px; font-weight: 500; color: var(--muted); margin-bottom: 3px; }
    .staff-exp   { font-size: 11px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: var(--gold); }
    .staff-certs-label { font-size: 9px; font-weight: 700; letter-spacing: .2em; text-transform: uppercase; color: var(--gold); margin-bottom: .7rem; }
    .staff-cert-list { list-style: none; display: flex; flex-direction: column; gap: .45rem; }
    .staff-cert-list li { display: flex; align-items: flex-start; gap: 8px; font-size: 13px; color: var(--muted); line-height: 1.5; }
    .staff-cert-list li::before { content: ''; width: 4px; height: 4px; background: var(--gold); flex-shrink: 0; margin-top: 6px; clip-path: polygon(50% 0%,0% 100%,100% 100%); }
    .staff-cert-list li strong { color: var(--charcoal); font-weight: 700; }
    @media (max-width: 720px) { .staff-grid { grid-template-columns: 1fr; } }

    /* WHY */
    #why { background: var(--white); position: relative; overflow: hidden; }
    .why-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
    .why-features { display: flex; flex-direction: column; gap: 1.8rem; }
    .feature-item { display: flex; gap: 1.4rem; align-items: flex-start; }
    .feature-num { font-size: 2.4rem; font-weight: 800; letter-spacing: -.04em; color: rgba(184,146,74,.18); line-height: 1; flex-shrink: 0; width: 48px; }
    .feature-content h4 { font-size: .95rem; font-weight: 700; margin-bottom: .25rem; color: var(--navy); }
    .feature-content p { font-size: 13.5px; color: var(--muted); line-height: 1.7; }
    .vs-wrap { overflow-x: auto; border: 1px solid var(--border); border-radius: 12px; background: var(--white); }
    .vs-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .vs-table th { font-size: 10px; font-weight: 700; letter-spacing: .15em; text-transform: uppercase; color: var(--muted); padding: .7rem .85rem; text-align: left; border-bottom: 1px solid var(--stone); }
    .vs-table th.col-a { color: var(--gold); }
    .vs-table td { padding: .65rem .85rem; border-bottom: 1px solid rgba(214,209,200,.5); color: var(--muted); vertical-align: top; line-height: 1.5; }
    .vs-table tr:last-child td { border-bottom: none; }
    .vs-table td.row-label { font-weight: 600; color: var(--charcoal); white-space: nowrap; }
    .vs-table td.col-a { color: var(--navy); font-weight: 600; }
    .check { color: var(--gold); }
    .dsa-callout { background: rgba(184,146,74,.08); border: 1px solid rgba(184,146,74,.2); border-radius: 10px; padding: 1.1rem 1.3rem; margin-top: 1.5rem; display: flex; gap: 12px; align-items: flex-start; }
    .dsa-callout svg { width: 18px; height: 18px; color: var(--gold); flex-shrink: 0; margin-top: 2px; }
    .dsa-callout p { font-size: 13px; color: var(--charcoal); line-height: 1.6; }
    .dsa-callout p strong { color: var(--navy); font-weight: 700; }

    /* PROCESS */
    #process { background: var(--navy); position: relative; overflow: hidden; }
    #process .section-tag { color: var(--gold); }
    #process h2 { color: var(--white); }
    #process .section-lead { color: rgba(234,226,214,.48); }
    .process-steps { display: grid; grid-template-columns: repeat(4,1fr); gap: 2rem; }
    .step-num { font-size: 2.8rem; font-weight: 800; letter-spacing: -.04em; color: rgba(184,146,74,.18); line-height: 1; margin-bottom: 1.2rem; }
    .step-div  { width: 32px; height: 1px; background: var(--gold); margin-bottom: 1.2rem; opacity: .4; }
    .process-step h4 { font-size: .9rem; font-weight: 700; color: var(--white); margin-bottom: .45rem; }
    .process-step p { font-size: 13px; color: rgba(234,226,214,.48); line-height: 1.7; }

    /* SELECTED PROJECTS */
    #projects { background: var(--navy); }
    #projects .section-tag { color: var(--gold); }
    #projects h2 { color: var(--white); }
    #projects .section-lead { color: rgba(234,226,214,.48); }
    .projects-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.25rem; }
    .project-card { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 12px; padding: 1.6rem; transition: background .2s, border-color .2s; }
    .project-card:hover { background: rgba(255,255,255,.07); border-color: rgba(184,146,74,.3); }
    .project-sector { display: inline-flex; align-items: center; gap: 6px; font-size: 10px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--gold); margin-bottom: .9rem; }
    .project-sector::before { content: ''; width: 4px; height: 4px; background: var(--gold); border-radius: 50%; flex-shrink: 0; }
    .project-card h3 { font-size: .95rem; font-weight: 800; color: var(--white); margin-bottom: .4rem; line-height: 1.3; letter-spacing: -.01em; }
    .project-meta { font-size: 12px; color: rgba(234,226,214,.4); margin-bottom: .6rem; }
    .project-card p { font-size: 13px; color: rgba(234,226,214,.5); line-height: 1.65; }
    .project-scope { display: flex; flex-wrap: wrap; gap: .35rem; margin-top: .85rem; }
    .project-tag { font-size: 10px; font-weight: 600; letter-spacing: .06em; text-transform: uppercase; color: rgba(184,146,74,.7); background: rgba(184,146,74,.1); border-radius: 100px; padding: 3px 9px; }

    /* WHO WE SERVE */
    #serve { background: var(--sand); }
    .serve-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; }
    .serve-card { background: var(--white); border: 1px solid var(--border); border-radius: 12px; padding: 2rem; }
    .serve-icon { width: 32px; height: 32px; color: var(--gold); margin-bottom: 1rem; }
    .serve-card h3 { font-size: 1rem; font-weight: 700; color: var(--navy); margin-bottom: .5rem; }
    .serve-card p { font-size: 13.5px; color: var(--muted); line-height: 1.7; }

    /* CONTACT */
    #contact { background: var(--white); position: relative; overflow: hidden; }
    .contact-grid { display: grid; grid-template-columns: 1fr 1.35fr; gap: 5rem; align-items: start; position: relative; z-index: 1; }
    .contact-info p { font-size: 15px; color: var(--muted); line-height: 1.8; margin-bottom: 2rem; }
    .contact-detail { display: flex; align-items: flex-start; gap: 12px; font-size: 13.5px; color: var(--muted); margin-bottom: .9rem; }
    .contact-detail svg { width: 16px; height: 16px; color: var(--gold); flex-shrink: 0; margin-top: 3px; }
    .contact-urgent { margin-top: 2rem; padding: 1.1rem 1.3rem; background: rgba(20,34,53,.06); border-radius: 8px; font-size: 13px; color: var(--muted); line-height: 1.6; }
    .contact-urgent strong { color: var(--navy); font-weight: 700; }
    .contact-form { background: var(--sand); border: 1px solid var(--stone); border-radius: 14px; padding: 2.6rem; }
    .form-group { margin-bottom: 1.1rem; }
    .form-group label { display: block; font-size: 10px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--muted); margin-bottom: .4rem; }
    .form-group input, .form-group select, .form-group textarea { width: 100%; background: var(--white); border: 1px solid var(--stone); border-radius: var(--radius); color: var(--charcoal); font-family: 'Manrope', sans-serif; font-size: 14px; font-weight: 500; padding: 11px 14px; transition: border-color .2s; outline: none; -webkit-appearance: none; }
    .form-group input::placeholder, .form-group textarea::placeholder { color: var(--stone); }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: var(--gold); }
    .form-group select { cursor: pointer; }
    .form-group select option { background: #fff; }
    .form-group textarea { resize: vertical; min-height: 100px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .form-submit { width: 100%; padding: 14px; font-size: 13px; border-radius: 100px; margin-top: .5rem; }
    .form-success { display: none; text-align: center; padding: 2.5rem 1rem; }
    .form-success strong { display: block; font-size: 1.3rem; font-weight: 800; color: var(--navy); margin-bottom: .5rem; }
    .form-success p { font-size: 14px; color: var(--muted); }

    /* FOOTER */
    footer { background: var(--navy); padding: 3rem 2rem; }
    .footer-inner { max-width: var(--max); margin: 0 auto; display: grid; grid-template-columns: auto 1fr auto; gap: 3rem; align-items: start; flex-wrap: wrap; }
    footer .logo-name { color: var(--white); }
    footer .logo-sub  { color: var(--gold); }
    .footer-id-tags { display: flex; flex-direction: column; gap: .55rem; }
    .footer-id-tags p { font-size: 10px; font-weight: 700; letter-spacing: .18em; text-transform: uppercase; color: rgba(234,226,214,.28); margin-bottom: .3rem; }
    .footer-id-tag { display: flex; align-items: center; gap: 8px; font-size: 11.5px; font-weight: 500; color: rgba(234,226,214,.45); }
    .footer-id-tag::before { content: ''; width: 4px; height: 4px; background: var(--gold); border-radius: 50%; opacity: .5; flex-shrink: 0; }
    .footer-right { text-align: right; align-self: end; }
    .footer-copy { font-size: 12px; color: rgba(234,226,214,.3); line-height: 1.9; }
    .footer-juris { font-size: 11px; color: rgba(234,226,214,.22); margin-top: .5rem; }

    /* RESPONSIVE */
    /* ── HAMBURGER ── */
    .hamburger { display: none; flex-direction: column; justify-content: center; gap: 5px; width: 36px; height: 36px; background: none; border: none; cursor: pointer; padding: 4px; flex-shrink: 0; }
    .hamburger span { display: block; height: 1.5px; background: var(--navy); border-radius: 2px; transition: transform .25s, opacity .2s; }
    .hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

    /* mobile nav drawer */
    .mobile-nav {
      display: none; position: fixed; top: 68px; left: 0; right: 0; bottom: 0;
      background: rgba(253,250,247,0.98); backdrop-filter: blur(16px);
      z-index: 99; flex-direction: column; padding: 2rem 1.5rem;
      overflow-y: auto;
    }
    .mobile-nav.open { display: flex; }
    .mobile-nav ul { list-style: none; display: flex; flex-direction: column; gap: .25rem; margin-bottom: 2rem; }
    .mobile-nav ul li a {
      display: block; font-size: 1.15rem; font-weight: 700; color: var(--navy);
      text-decoration: none; padding: .85rem 0;
      border-bottom: 1px solid var(--border); letter-spacing: -.01em;
    }
    .mobile-nav ul li a:hover { color: var(--gold); }
    .mobile-nav .btn-gold { width: 100%; text-align: center; padding: 15px; font-size: 13px; }
    .mobile-nav-identity { margin-top: 2rem; display: flex; flex-direction: column; gap: .5rem; }
    .mobile-nav-identity span { font-size: 11px; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--muted); display: flex; align-items: center; gap: 8px; }
    .mobile-nav-identity span::before { content: ''; width: 4px; height: 4px; background: var(--gold); border-radius: 50%; flex-shrink: 0; }

    /* ── TABLET ── */
    @media (max-width: 980px) {
      .hero-inner      { grid-template-columns: 1fr; }
      .hero-creds      { display: none; }
      .services-layout { grid-template-columns: 1fr; }
      .service-nav     { position: static; display: none; }
      .panel-items     { grid-template-columns: 1fr; }
      .why-grid        { grid-template-columns: 1fr; gap: 3rem; }
      .contact-grid    { grid-template-columns: 1fr; gap: 3rem; }
      .process-steps   { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
      .serve-grid      { grid-template-columns: 1fr 1fr; }
      .projects-grid   { grid-template-columns: 1fr 1fr; }
      .diff-inner      { grid-template-columns: 1fr 1fr; }
      .creds-intro     { grid-template-columns: 1fr; gap: 1.5rem; }
      .cert-summary    { grid-template-columns: repeat(3,1fr); }
      .footer-inner    { grid-template-columns: 1fr 1fr; }
      .staff-grid      { grid-template-columns: 1fr 1fr; }
    }

    /* ── MOBILE ── */
    @media (max-width: 620px) {
      h1 { font-size: 2.2rem; }
      h2 { font-size: 1.75rem; }

      /* nav — show hamburger, hide desktop links */
      .nav-links, .nav-cta { display: none; }
      .hamburger { display: flex; }

      /* hero */
      #hero { padding: 4rem 1.25rem 3rem; min-height: auto; }
      .hero-lead { font-size: 15px; }
      .hero-family { font-size: 13px; }
      .hero-cta { flex-direction: column; }
      .hero-cta a { text-align: center; }
      .jurisdiction-row { gap: .35rem; }
      .juris-tag { font-size: 10px; padding: 3px 9px; }

      /* identity band */
      #identity-band { padding: .6rem 1.25rem; }
      .identity-inner { gap: .3rem 1rem; justify-content: flex-start; }
      .id-tag { font-size: 9.5px; }

      /* diff band */
      #diff-band { padding: 2.5rem 1.25rem; }
      .diff-inner { grid-template-columns: 1fr; gap: 1.5rem; }

      /* sections */
      section { padding: 3.5rem 1.25rem; }
      .section-lead { margin-bottom: 2.5rem; }
      nav, #diff-band, #identity-band { padding-left: 1.25rem; padding-right: 1.25rem; }

      /* services */
      .panel-items { grid-template-columns: 1fr; }

      /* cert tabs — make them scrollable row */
      .cert-tabs { flex-wrap: nowrap; overflow-x: auto; padding-bottom: .5rem; -webkit-overflow-scrolling: touch; gap: .4rem; }
      .cert-tabs::-webkit-scrollbar { display: none; }
      .cert-tab { white-space: nowrap; flex-shrink: 0; }

      /* cert summary */
      .cert-summary { grid-template-columns: repeat(3,1fr); gap: .6rem; }
      .cert-summary-item { padding: .8rem .6rem; }
      .cert-summary-body { font-size: .9rem; }
      .cert-summary-label { font-size: 9px; }

      /* team grid — single col */
      .team-grid  { grid-template-columns: 1fr; }
      .juris-grid { grid-template-columns: 1fr; }
      .staff-grid { grid-template-columns: 1fr; }

      /* comparison table — Asenso column only on mobile */
      .vs-table thead tr th:nth-child(3),
      .vs-table thead tr th:nth-child(4),
      .vs-table tbody tr td:nth-child(3),
      .vs-table tbody tr td:nth-child(4) { display: none; }
      .vs-table th, .vs-table td { padding: .55rem .65rem; font-size: 12px; }
      .vs-table th.col-a, .vs-table td.col-a { min-width: 120px; }
      .vs-mobile-note { display: block; font-size: 11px; color: var(--muted); margin-top: .75rem; font-style: italic; }

      /* process */
      .process-steps { grid-template-columns: 1fr; }

      /* who we serve */
      .serve-grid { grid-template-columns: 1fr; }
      .projects-grid { grid-template-columns: 1fr; }

      /* form */
      .form-row { grid-template-columns: 1fr; }

      /* footer */
      .footer-inner { grid-template-columns: 1fr; gap: 2rem; }
      .footer-right { text-align: left; }

      /* why grid */
      .why-grid { grid-template-columns: 1fr; gap: 3rem; }
    }

    /* note shown only on mobile below comparison table */
    .vs-mobile-note { display: none; }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-inner">
    <a href="#" class="logo">
      <svg class="logo-mark" viewBox="0 0 36 36" fill="none">
        <path d="M4 24 C8 24,10 14,15 14 C20 14,21 24,26 24 C29 24,30.5 20,33 18" stroke="#B8924A" stroke-width="2" stroke-linecap="round" fill="none"/>
        <path d="M2 18 C6 18,8 10,13 10 C18 10,19 22,24 22 C27 22,28.5 18,33 16" stroke="#B8924A" stroke-width="1.2" stroke-linecap="round" fill="none" opacity=".35"/>
        <path d="M14 30 L17 26 L20 30 Z" fill="#B8924A" opacity=".2"/>
      </svg>
      <div class="logo-text">
        <span class="logo-name">ASENSO</span>
        <span class="logo-sub">Special Inspections</span>
      </div>
